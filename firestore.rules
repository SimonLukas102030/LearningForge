rules_version = '2';

// ════════════════════════════════════════════════════════════════════════════
//  LearningForge — Firestore Security Rules
//
//  Deploy: firebase deploy --only firestore:rules
//
//  Mission 2 Phase 2 (Marcus Hayes, 2026-05-07): hardening pass after
//  Ramsey's Red-Team-Cycle-1 audit. Field-level allow-list on users,
//  XP-delta cap, klasse-validator, leaderboard/dailyScores clamps,
//  comment-likes-self-only, dead pendingTopics block removed, feed
//  author-only update/delete, group-members own-key-only, bugReports
//  uid-bind, shareLinks owner-only-read, users.list admin-only.
//  Soft-caps mark spots where Cloud Functions (Mission 3 ADR) are the
//  real fix.
//
//  Wave-1 hardening (Marcus, 2026-05-08, post-XXL-Polish-Cycle Phase 3):
//   - CHEAT-23  themeDrops dropped from ownerSafeFields (worker-only writes)
//   - CHEAT-26  activeOutline/activeTheme must be in owned list
//   - CHEAT-27  friendRequests role spoofing blocked (cross-check user-doc)
//   - CHEAT-29  bugReports name/photoURL spoofing blocked (cross-check)
//   - CHEAT-30  comment name/photo/role spoofing blocked (cross-check)
//   - CHEAT-33  comment text-size cap + createdAt == request.time
//   - CHEAT-34  klasse mirror to leaderboard now allowed (cross-check)
//   - CHEAT-38  shareLinks expiresAt required at create
//   - B-M01     appConfig rule added (admin-write, auth-read)
//   - B-M02     groups.update self-join carve-out re-added
//   - B-M04     leaderboard xp/displayName/photoURL/role mirrors allowed
//   - B-M05     leaderboard owner-mirror cross-checks user-doc values
//   - B-M07     dailyChallengesCompleted / srs / questions counter caps
// ════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helper functions ──────────────────────────────────────────────────
    function isAuth()        { return request.auth != null; }
    function isOwner(uid)    { return isAuth() && request.auth.uid == uid; }
    function isAdmin()       { return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function onlyChanged(fs) { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fs); }

    // V-03 (Ramsey audit cycle 2026-05-08): hardcoded admin/tester whitelist
    // split into two tiers so a tester credential cannot self-promote to
    // admin. Previously a single adminOrTesterEmail() set granted Case-B
    // (arbitrary self-writes incl. role/isBanned/isClaude/isHacker) to BOTH
    // Simon and the tester account — a leaked tester password would have
    // been an admin-promotion vector via the Firebase console.
    //
    //   adminEmails()  = full Case-B (role-sensitive self-writes)
    //   testerEmails() = Case-B-tester (owner-safe-fields without soft-caps,
    //                    but NOT role/isBanned/isClaude/isHacker)
    //
    // The previous adminOrTesterEmail() union helper was removed because no
    // rule references it after the split; reintroduce as
    // `adminEmails().concat(testerEmails())` if a rule ever needs the union.
    function adminEmails() {
      return ['simonkoper27@gmail.com'];
    }
    function testerEmails() {
      return ['bohmrobin797@gmail.com'];
    }

    // V-PHASE-E-05 (Ramsey Cycle-E, P1, 2026-05-08): defense-in-depth
    // email-verification gate on the admin-email whitelist. The Firebase
    // Auth ID-token already carries `email_verified`; without this check
    // a freshly-registered (or password-reset) account using one of the
    // whitelisted email addresses but with `email_verified=false` would
    // pass the email-string match. That's a thin attack surface (Simon's
    // email is verified), but matching the Worker's check (which also
    // pins email_verified) keeps the layers consistent and blocks the
    // unverified-impersonation case. Used by every rule that checks
    // `request.auth.token.email in adminEmails()`.
    function isAdminEmail() {
      return isAuth()
          && request.auth.token.email_verified == true
          && request.auth.token.email in adminEmails();
    }

    // Explicit allow-list of user-doc fields a normal owner may write to
    // their own doc. EXCLUDES role, isBanned, isClaude, isHacker — those
    // are role-sensitive and only writable via the admin-whitelist branch
    // or by a real admin.
    //
    // Wave-1 hardening 2026-05-08 (Marcus, CHEAT-23 from Ramsey):
    //   `themeDrops` REMOVED from this list. The only legitimate writer
    //   for themeDrops is the submitTestResult worker (service-account,
    //   bypasses rules). A direct client `set({themeDrops:[...]},
    //   {merge:true})` to forge "I rolled this drop" was the bypass for
    //   unlockCosmetic's drop-history check (themeDrops includes id ->
    //   arrayUnion themes). With themeDrops out of ownerSafeFields the
    //   write is denied — Mission-7 Variant-B server-roll is the only
    //   legitimate path to a new theme.
    function ownerSafeFields() {
      return [
        'name', 'photoURL', 'klasse', 'email', 'createdAt', 'onboardedAt',
        'grades', 'xp', 'xpLog',
        'achievements', 'bookmarks', 'notes', 'srs', 'studyTime',
        'freezeDays', 'dailyChallenges', 'totalQuestionsAnswered',
        'srsReviewsTotal', 'dailyChallengesCompleted',
        'streakCount', 'lastStreakDate', 'testsToday',
        'activeOutline', 'activeTheme', 'outlines', 'themes',
        'friendIds', 'friendRequests', 'friendRequestsSent', 'groupIds',
        'weakQuestions',
        // Mission 1 settings page (Farben + Icons pro Fach)
        'settings',
        // Mission 4 (App-Tour) state — toast-trigger + completion markers
        'tourCompletedAt', 'tourSkippedAt', 'tourPromptedAt',
        // Cycle-Features 2026-05-08: F-1 Klausur-Countdown (Array of exam
        // entries) + F-3 Erklär-mir-warum-falsch (Map of qId -> explanation
        // cache). Both self-write-only, no cross-user-write surface. No
        // soft-cap in V1 — Mission-3-Followup if size becomes relevant
        // (exams capped naturally by user behaviour ~20/year, error
        // explanations frontend-rate-limited at 20/day via localStorage).
        'exams', 'errorExplanations'
      ];
    }

    // CHEAT-26 (Wave-1, Marcus, 2026-05-08): activeOutline/activeTheme must
    // be in the user's owned list before being set as active. Without this
    // a user could `set({activeOutline:'cosmic'}, {merge:true})` to wear a
    // legendary outline they never earned. The owned-list check covers all
    // outlines-user-doc state (admin/tester unlock-all, drop-roll-derived,
    // etc.) — anything in `outlines` is by definition legitimate.
    //
    // 'none' (outline) and 'default' (theme) are always allowed even when
    // not in the owned-list, because they are the no-cosmetic fallback.
    //
    // Field absent in resource = old doc lacked it; treat that as still
    // "no change to the affected key" to avoid blocking unrelated writes.
    function activeOutlineOk() {
      return !('activeOutline' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.activeOutline == null
          || request.resource.data.activeOutline == 'none'
          || (request.resource.data.outlines is list
              && request.resource.data.activeOutline in request.resource.data.outlines);
    }
    function activeThemeOk() {
      return !('activeTheme' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.activeTheme == null
          || request.resource.data.activeTheme == 'default'
          || (request.resource.data.themes is list
              && request.resource.data.activeTheme in request.resource.data.themes);
    }

    // Soft-cap helpers (real fix = Cloud Function in Mission 3 ADR)
    // ----------------------------------------------------------------
    // XP delta per write capped at 200 (rough max from one perfect
    // 90-min test plus achievement rewards).
    function xpDeltaOk() {
      return !('xp' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.xp is number
              && request.resource.data.xp - resource.data.get('xp', 0) <= 200);
    }

    // Klasse must be one of the allowed grade strings 5..13.
    //
    // Wave-1 transitional fix (Marcus, 2026-05-08, B-M08): legacy users
    // (pre-Mission-2 era) have a NUMERIC `klasse` field on their user-doc.
    // Mission 2 standardised writes on String(klasse), but Bestands-User-
    // Docs were never migrated. Firestore-rules type-strictly compare
    // `9 in ['5'..,'13']` -> false, so EVERY set+merge by a legacy
    // numeric-klasse user was denied (the projected `klasse` after merge
    // is still numeric). The frontend-side migration (forward-only,
    // client-init) is Ethan's lane (B-M08); until all legacy users have
    // logged in once and triggered the migration, the rule accepts BOTH:
    //   - numeric 5..13 (legacy, transitional)
    //   - string  '5'..'13' (canonical)
    // After the migration has soaked through the user base (probably
    // ~30 days), drop the numeric branch in a follow-up wave.
    function klasseOk() {
      return !('klasse' in request.resource.data)
          || request.resource.data.klasse in ['5','6','7','8','9','10','11','12','13']
          || request.resource.data.klasse in [5,6,7,8,9,10,11,12,13];
    }

    // Outlines / themes / achievements: bound growth per write.
    // Real fix = server-side validation that the user actually earned
    // the new entries (Mission 3). Inlined per-field below because
    // Firestore-rules helpers cannot index maps by a variable name.
    //
    // B8 fix (2026-05-08, Marcus, P0 bug-cycle-3): achievements cap
    // raised 2 → 8 after Robinator's "man kann gar keine Erfolge mehr
    // bekommen" report. A fresh user finishing their first good test
    // legitimately unlocks several at once via grantXPAndAchievements()
    // in app.js (line 5601 saveAchievements arrayUnion):
    //   first_test, first_one, perfect_score, level_5, daily_first,
    //   time_60, srs_10, ... — easily 3-5 in a single write. The
    //   2-cap silently rejected the entire arrayUnion (rule denies
    //   the WHOLE doc-write, not just the achievements field), and
    //   because saveAchievements has a silent .catch upstream the
    //   user just sees no toast and no badge. Cap of 8 covers the
    //   realistic mass-unlock scenario without opening a wide cheat
    //   vector — a malicious client would still need to NAME real
    //   achievement IDs and the server-side worker re-derives the
    //   authoritative list anyway via deriveNewAchievements().
    // outlines/themes stay at 2 — those don't have the same mass-grant
    // pattern (max 1 outline per level-tier-cross, 1 theme per drop-roll).
    function outlinesGrowthOk() {
      return !('outlines' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.outlines.size() - resource.data.get('outlines', []).size() <= 2);
    }
    function themesGrowthOk() {
      return !('themes' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.themes.size() - resource.data.get('themes', []).size() <= 2);
    }
    function achievementsGrowthOk() {
      return !('achievements' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.achievements.size() - resource.data.get('achievements', []).size() <= 8);
    }

    // V-25 (Ramsey Cycle-2 audit, P2 MED, 2026-05-08): studyTime is a
    // map { 'YYYY-MM-DD': minutes } that was previously uncapped via
    // ownerSafeFields(). A user could `set({studyTime: {'2026-05-08':
    // 9999999, '2026-05-07': 9999999, ...}}, {merge:true})` directly
    // from the browser console and fake-fill the entire Heatmap, inflate
    // the leaderboard `studyMins` display, and trigger time-based
    // achievements (the Worker re-derives those from studyTime on the
    // next submitTestResult).
    //
    // FIRESTORE-RULES LIMITATION: rules cannot iterate a map's values
    // with a lambda (no `.all(v => ...)` syntax) and cannot index a map
    // by a runtime-determined key. The proper per-day value cap (e.g.
    // <= 1440 min/day) requires server-side validation. Mission 3 ADR.
    //
    // What we CAN enforce here, and what blocks the bulk-fake attack:
    //   - At most 1 top-level key in studyTime is affected per write.
    //   - The studyTime map grows by at most 1 entry per write.
    // Combined: a user can only legitimise one new day-key per write,
    // so faking a green Heatmap requires N sequential writes (one per
    // day) — detectable, rate-limitable, no longer a single-shot bulk
    // attack. Per-day VALUE cap stays in the Worker.
    function studyTimeDeltaOk() {
      return !('studyTime' in request.resource.data.diff(resource.data).affectedKeys())
          || (
               request.resource.data.studyTime is map
               && request.resource.data.studyTime
                    .diff(resource.data.get('studyTime', {}))
                    .affectedKeys().size() <= 1
               && request.resource.data.studyTime.size()
                    - resource.data.get('studyTime', {}).size() <= 1
             );
    }

    // B-M07 (Wave-1, Marcus, 2026-05-08): per-write delta caps for the
    // counter fields in ownerSafeFields(). Without these caps a user
    // could `set({dailyChallengesCompleted: 9999}, {merge:true})` from
    // the console and unlock `daily_7` / `daily_30` achievements
    // instantly. The Worker (submitDailyChallenge) increments by exactly
    // 1 per legitimate submit; the test-engine bumps totalQuestionsAnswered
    // by question-count (max ~25 per 90-min test) and srsReviewsTotal by
    // a few tens per session. Caps are generous: dailyChallenges +1 per
    // write (atomic counter increment), srsReviews + 50, questions + 50.
    // The Worker writes via Service-Account so it bypasses these caps.
    //
    // RULES-LIMITATION: Firestore rules can't index `request.resource.data`
    // with a runtime field name, so we inline one helper per field instead
    // of a parameterised counterDeltaOk(field, cap) generic.
    function dailyCompletedDeltaOk() {
      return !('dailyChallengesCompleted' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.dailyChallengesCompleted is number
              && request.resource.data.dailyChallengesCompleted
                   - resource.data.get('dailyChallengesCompleted', 0) <= 1
              && request.resource.data.dailyChallengesCompleted
                   - resource.data.get('dailyChallengesCompleted', 0) >= 0);
    }
    function srsReviewsDeltaOk() {
      return !('srsReviewsTotal' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.srsReviewsTotal is number
              && request.resource.data.srsReviewsTotal
                   - resource.data.get('srsReviewsTotal', 0) <= 50
              && request.resource.data.srsReviewsTotal
                   - resource.data.get('srsReviewsTotal', 0) >= 0);
    }
    function totalQAnsweredDeltaOk() {
      return !('totalQuestionsAnswered' in request.resource.data.diff(resource.data).affectedKeys())
          || (request.resource.data.totalQuestionsAnswered is number
              && request.resource.data.totalQuestionsAnswered
                   - resource.data.get('totalQuestionsAnswered', 0) <= 50
              && request.resource.data.totalQuestionsAnswered
                   - resource.data.get('totalQuestionsAnswered', 0) >= 0);
    }

    // ── users ─────────────────────────────────────────────────────────────
    // Read:    any auth'd user may .get() a single user doc (needed for
    //          friend lookups, comment-author display, etc.).
    // List:    only admins may .list() the whole collection. This locks
    //          down getAllUsers() / mass email-harvest (Cheat #18).
    // Create:  only own doc.
    // Update:
    //   A) owner writes ONLY safe fields (no role-escalation possible)
    //      AND klasse stays in 5..13
    //      AND xp delta <= 200
    //      AND outlines/themes/achievements grow by <= 2 per write
    //   B-admin) owner is on the admin email whitelist — may also write
    //      role-sensitive fields to their own doc (markAsClaude etc.).
    //   B-tester) owner is on the tester email whitelist — may write the
    //      full ownerSafeFields() set without soft-caps (so testWipeAll /
    //      testSetXP / testUnlockAllThemes can ignore xpDelta/outlines/
    //      themes/achievements growth limits). May ADDITIONALLY write
    //      `role` to their own doc, but ONLY with value 'tester' — never
    //      'admin' / 'hacker' (so a leaked tester credential cannot
    //      self-promote). Must still NOT touch isBanned / isClaude /
    //      isHacker. (V-03 fix 2026-05-07; tester-role-sync re-enabled
    //      2026-05-08 after Sophie's Cycle-2 P0 finding — syncUserRole
    //      in auth.js writes role:'tester' on every login and was
    //      blanket-denied by the previous version of this case.)
    //   C) any user with role:'admin' on their own doc — full access
    //   D-friendRequests) cross-user friendRequests-only write where
    //      the requesting user only touches their OWN UID-key in the
    //      map (used by sendFriendRequest). V-26 hardening: prevents
    //      the unbounded-spam-keys DoS that would bloat the victim's
    //      user-doc to the 1MB limit.
    //   D-friendIds/groupIds) cross-user array-membership writes
    //      (used by acceptFriendRequest writing to requester, unfriend,
    //      kickFromGroup, group-deletion ripple). Looser bound — the
    //      auth UID is not always the affected element.
    // Delete:  only own doc or admin.
    match /users/{uid} {
      allow get:    if isAuth();
      allow list:   if isAdmin();
      allow create: if isOwner(uid);
      allow update: if (
                        // Case A: owner writing only safe fields
                        (isOwner(uid)
                          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(ownerSafeFields())
                          && klasseOk()
                          && xpDeltaOk()
                          && outlinesGrowthOk()
                          && themesGrowthOk()
                          && achievementsGrowthOk()
                          && studyTimeDeltaOk()
                          // CHEAT-26 (2026-05-08, Wave-1, Marcus): activeOutline/
                          // activeTheme must reference an owned cosmetic, otherwise
                          // a user could equip legendary themes/outlines via
                          // `set({activeOutline:'cosmic'}, {merge:true})`.
                          && activeOutlineOk()
                          && activeThemeOk()
                          // B-M07 (Wave-1, Marcus): cap the counter-increment
                          // fields so a user cannot `set({dailyChallenges
                          // Completed: 9999})` to unlock daily_7/daily_30 or
                          // similar achievement gates instantly.
                          && dailyCompletedDeltaOk()
                          && srsReviewsDeltaOk()
                          && totalQAnsweredDeltaOk())
                        // Case B-admin: full Case-B power for the admin whitelist.
                        // V-PHASE-E-05 (2026-05-08): isAdminEmail() now requires
                        // email_verified=true on the ID token (defense-in-depth
                        // against unverified-email impersonation).
                        || (isOwner(uid) && isAdminEmail())
                        // Case B-tester: owner-safe-fields without soft-caps.
                        // May ALSO write `role` if and only if the new value is
                        // 'tester' (so syncUserRole in auth.js can self-set the
                        // role on login, but a leaked tester credential cannot
                        // self-promote to 'admin' or anything else). Must not
                        // touch isBanned / isClaude / isHacker — those are
                        // never in ownerSafeFields() and `role` is the only
                        // role-sensitive field added to the diff allow-list.
                        || (isOwner(uid)
                            && request.auth.token.email in testerEmails()
                            && request.resource.data.diff(resource.data).affectedKeys()
                                 .hasOnly(ownerSafeFields().concat(['role']))
                            && (
                                 !('role' in request.resource.data.diff(resource.data).affectedKeys())
                                 || request.resource.data.role == 'tester'
                               ))
                        // Case C: real admin (any user with role:'admin' in their own doc)
                        || isAdmin()
                        // Case D-friendRequests (V-26 Ramsey Cycle-2 audit,
                        // P2 MED, 2026-05-08): when the cross-user write
                        // ONLY touches `friendRequests`, the requesting user
                        // may only add/change THEIR OWN UID-key in the map.
                        // Previously Case D was a single broad branch that
                        // let any auth user merge arbitrary keys into ANY
                        // user's friendRequests map — `for (i=0; i<10000;
                        // i++) set({friendRequests: {[`spam_${i}`]:...}})`
                        // would bloat the victim's user-doc to the 1MB
                        // limit (app fails to load).
                        //
                        // hasOnly([request.auth.uid]) means only the
                        // sender's own UID-key can appear in the diff —
                        // re-sending an already-pending request still
                        // works (overwrite of own key), but no other
                        // keys can be touched (no spam, no clearing
                        // someone else's pending requests).
                        //
                        // Wave-1 hardening 2026-05-08 (Marcus, CHEAT-27/30):
                        // the role/name/photo on the friendRequest entry
                        // MUST match the sender's actual user-doc so an
                        // attacker cannot impersonate "Simon (admin)" in
                        // a friend-request notification. The role-check
                        // is the critical one — UI badges trust it and
                        // an admin-impersonator could phish credentials.
                        //
                        // Followup (Mission 3 scope): move friendRequests
                        // into a subcollection `users/{uid}/friendRequests/
                        // {fromUid}` so each request is its own doc and
                        // the 1MB user-doc limit is no longer a vector.
                        || (isAuth()
                            && onlyChanged(['friendRequests'])
                            && request.resource.data.friendRequests
                                 .diff(resource.data.get('friendRequests', {}))
                                 .affectedKeys()
                                 .hasOnly([request.auth.uid])
                            && (
                                 // Removal/null-clear of the sender's own
                                 // pending request is always OK (cancel-
                                 // sent path; null-marker pattern instead
                                 // of FieldValue.delete per Hard rule 5).
                                 request.resource.data.friendRequests[request.auth.uid] == null
                                 ||
                                 // Add/overwrite path: role MUST mirror the
                                 // sender's own user-doc — admin-impersonation
                                 // is the critical vector (badges trust role).
                                 // name MUST also mirror — UI shows the sender
                                 // name verbatim, no impersonation. photo can
                                 // mirror OR be null (auth.photoURL gets
                                 // nulled when the user uploads a large
                                 // data-URL profile pic; auth.js:50-53 has
                                 // the size-limit. So the legitimate "no
                                 // photo on Auth, big photo on Firestore"
                                 // case must still go through).
                                 (
                                   request.resource.data.friendRequests[request.auth.uid].role
                                     == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null)
                                   && request.resource.data.friendRequests[request.auth.uid].name
                                        == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('name', null)
                                   && (
                                        request.resource.data.friendRequests[request.auth.uid].photo == null
                                        || request.resource.data.friendRequests[request.auth.uid].photo
                                             == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('photoURL', null)
                                      )
                                 )
                               ))
                        // Case D-friendIds/groupIds: cross-user array
                        // membership writes used by acceptFriendRequest
                        // (writes friendIds on the requester's doc),
                        // unfriend (writes friendIds on the friend's doc),
                        // leaveGroup creator-path (clears groupIds on all
                        // members), and kickFromGroup (clears groupIds on
                        // the kicked user). These use arrayUnion/Remove
                        // transforms; the auth UID is not always the
                        // affected element (kicker != kicked target), so
                        // we keep the broader rule here. Bounding these
                        // tighter is a Mission 3 followup.
                        // hasOnly() is a subset check, so this single
                        // branch covers writes touching only friendIds,
                        // only groupIds, or both together.
                        || (isAuth() && onlyChanged(['friendIds', 'groupIds']))
                      );
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ── groups ────────────────────────────────────────────────────────────
    // members carve-out REMOVED (Cheat #14), then SELF-JOIN-CARVEOUT
    // RE-ADDED (B-M02 Wave-1 hardening, Marcus, 2026-05-08): the previous
    // removal broke joinGroupByCode entirely — the joining user is not the
    // creator, so the "creatorUid == request.auth.uid || isAdmin()" branch
    // denied the members.{uid} write. Group-join has been silently broken
    // since the Cheat-#14-fix shipped.
    //
    // Self-join carve-out:
    //   - touches ONLY the `members` field (no name/code/creator rewrite)
    //   - the diff against members keys MUST be exactly [request.auth.uid]
    //   - the auth UID was NOT a member before (no double-join overwrite)
    // That last check stops a member from rewriting their OWN entry to
    // role:'admin' inside the members map (auth.js writes role:'member'
    // for joiners). It also blocks kick-and-rejoin races.
    //
    // Leaving a group via Hard-rule-4-compliant `set+merge` writes a null
    // marker on members.{uid}; the original member-entry is non-null so
    // `not in resource.data.members.keys()` no longer holds. Removal is
    // covered by either the creator path (creator clears another member),
    // or the user's OWN delete-pattern (set members.{uid}: null) below.
    match /groups/{groupId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.creatorUid == request.auth.uid;
      allow update:     if isAuth()
                         && (
                              // Case A: creator does anything they want.
                              resource.data.creatorUid == request.auth.uid
                              || isAdmin()
                              // Case B: self-join — touches only `members`,
                              // diff is exactly the auth uid, the auth uid
                              // was NOT already a member.
                              || (
                                   onlyChanged(['members'])
                                   && request.resource.data.members
                                        .diff(resource.data.members)
                                        .affectedKeys()
                                        .hasOnly([request.auth.uid])
                                   && !(request.auth.uid in resource.data.members)
                                 )
                              // Case C: self-leave — touches only `members`,
                              // diff is exactly the auth uid, the auth uid
                              // WAS a member (Hard-rule-5-compliant null-
                              // marker pattern: members.{uid}: null instead
                              // of FieldValue.delete).
                              || (
                                   onlyChanged(['members'])
                                   && request.resource.data.members
                                        .diff(resource.data.members)
                                        .affectedKeys()
                                        .hasOnly([request.auth.uid])
                                   && request.auth.uid in resource.data.members
                                 )
                            );
      allow delete:     if isAuth() && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    // ── leaderboard ───────────────────────────────────────────────────────
    // V-24 closed (Ramsey Cycle-2 audit, 2026-05-08): the previous
    // one-key-per-write soft-cap had no validation on the *value* — a user
    // could `set({scores: {topicKey: 999999}}, {merge:true})` on their own
    // leaderboard doc and claim Top-1 on every klassen-leaderboard without
    // earning the XP. The submitTestResult Cloud Worker (service-account
    // credentials, bypasses these rules) is now the ONLY writer for the
    // `scores` map.
    //
    // Owner-update is restricted to a small allow-list of NON-score display
    // fields so the existing client mirrors keep working:
    //   - setActiveTheme()   -> activeTheme
    //   - setActiveOutline() -> activeOutline
    //   - resetLeaderboard() -> scores (set to empty map only — explicit
    //                           guard below: scores must be {} after the
    //                           write, never grown)
    //
    // updateLeaderboard() in auth.js was the inflation vector and has been
    // deleted alongside this rule change (Cycle-2 commit). All test-save
    // leaderboard writes now go through the Worker exclusively.
    //
    // Admin write stays open for manual anomaly correction via admin
    // tooling. Reads stay auth-only so the Rangliste UI keeps working.
    // B-M04 / B-M05 / CHEAT-34 (Wave-1 hardening, Marcus, 2026-05-08):
    // `lbOwnerSafeFields()` was previously only `[activeTheme,
    // activeOutline, scores, updatedAt]` — too narrow. The Mirror-block in
    // `grantXPAndAchievements` (app.js:5593) writes xp/displayName/photoURL/
    // role to leaderboard/{uid}, and `setUserKlasse` (auth.js:setUserKlasse)
    // mirrors `klasse`. Both fail silent at the rules layer. Result: SRS-
    // power-users (no tests, only reviews) and class-changers see permanent
    // mirror-drift on the leaderboard.
    //
    // We add the missing fields to the allow-list AND add a per-write
    // `lbXpDeltaOk()` cap that mirrors users.xp's V-24 hardening — the
    // leaderboard worker (submitTestResult) is still authoritative because
    // it sets `xp` to (oldXp + totalXpDelta), but the owner can also write
    // their own `xp` value as long as it does not exceed `users.xp`. That
    // way an SRS-Mirror cannot inflate xp on the leaderboard while still
    // letting the cosmetic-pick-mirror (activeTheme/activeOutline) and the
    // legitimate xp-mirror (which equals the user-doc value) go through.
    //
    // klasse: must equal the user's actual users.{uid}.klasse (verified
    // server-side via get()). Otherwise a klasse-mirror could be used to
    // fake-jump leaderboards (e.g. set klasse:'12' to compete in 12th-grade
    // ranking without studying that material).
    //
    // role/displayName/photoURL: cross-checked the same way — the owner
    // mirrors what their users.{uid} doc already says, no impersonation.
    function lbOwnerSafeFields() {
      return [
        'activeTheme', 'activeOutline', 'scores', 'updatedAt',
        'xp', 'displayName', 'photoURL', 'role', 'klasse'
      ];
    }
    function lbXpEqualsUserDoc() {
      return !('xp' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.xp
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('xp', 0);
    }
    function lbKlasseEqualsUserDoc() {
      return !('klasse' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.klasse
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('klasse', null);
    }
    function lbDisplayNameEqualsUserDoc() {
      return !('displayName' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.displayName
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('name', null);
    }
    function lbPhotoEqualsUserDoc() {
      return !('photoURL' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.photoURL
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('photoURL', null);
    }
    function lbRoleEqualsUserDoc() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys())
          || request.resource.data.role
               == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null);
    }
    match /leaderboard/{uid} {
      allow read, list: if isAuth();
      allow create:     if isOwner(uid);
      allow update:     if (
                            isOwner(uid)
                            && request.resource.data.diff(resource.data).affectedKeys()
                                 .hasOnly(lbOwnerSafeFields())
                            // If `scores` is in the write, it MUST become {}
                            // (resetLeaderboard path). Inflation is blocked
                            // because no other key/value combination satisfies
                            // both this `is map`+`size==0` predicate and the
                            // hasOnly() above.
                            && (
                                 !('scores' in request.resource.data.diff(resource.data).affectedKeys())
                                 || (request.resource.data.scores is map
                                     && request.resource.data.scores.keys().size() == 0)
                               )
                            && lbXpEqualsUserDoc()
                            && lbKlasseEqualsUserDoc()
                            && lbDisplayNameEqualsUserDoc()
                            && lbPhotoEqualsUserDoc()
                            && lbRoleEqualsUserDoc()
                          )
                          || isAdmin();
      allow delete:     if isOwner(uid) || isAdmin();
    }

    // ── customTopics ──────────────────────────────────────────────────────
    // Phase 3c (Marcus, 2026-05-08): Public-Library-Approval-Workflow.
    // The `visibility` field is now a 4-state machine:
    //   'private'           — only owner reads (default for new topics)
    //   'group'             — owner + members of topic.groupId read
    //   'pending-approval'  — owner-only read while in queue (admin reads
    //                          via service-account / Worker bypass)
    //   'public'            — every authed user reads (Public-Library)
    //
    // Legacy topics (pre-Phase-3c) without a `visibility` field are
    // treated as 'private' for read-purposes — backwards-compat with
    // the pre-visibility schema where the only readers were owner +
    // group via the `groupId` field. Owners can still always read.
    //
    // Client writes:
    //   - create: ownerUid must match auth.uid AND visibility (if set)
    //             must be in the client-writable subset 'private'|'group'.
    //             Worker-only states ('pending-approval', 'public') are
    //             blocked at create-time so a malicious client can't
    //             skip the queue.
    //   - update: owner may write any field EXCEPT setting visibility
    //             to a worker-only state. Setting visibility to
    //             'private' or 'group' is fine (covers group-share
    //             toggle from the Builder UI). Admin/admin-email keeps
    //             full power. Approval-state transitions ('pending-approval'
    //             -> 'public', '-> 'group' on reject) come from the
    //             approveTopicForPublic Worker which uses a service
    //             account and bypasses these rules.
    //   - delete: owner only (admin keeps power).
    //
    // List queries: stay open for now — the auth.js wrappers
    // (getMyCustomTopics / getGroupCustomTopics) already filter by
    // ownerUid/groupId so legitimate queries are scoped. A future
    // hardening could split list into dedicated where-clause checks
    // (mission-3 followup).
    // Inlined (no `let`) to match the rest of the file's style — every
    // other rules-helper here uses straight expression chains, and the
    // Firestore rules-engine evaluator inlines them anyway. The triple
    // resource.data.get(...) lookups are cheap (no doc reads — they
    // operate on the already-loaded existing-doc snapshot).
    //
    // Legacy-compat (Phase 3c, Marcus, 2026-05-08): topics created BEFORE
    // the `visibility` field was added have no `visibility` set on their
    // doc. We map them to a synthetic visibility based on `groupId`:
    //   - groupId == null  -> 'private' (matches old getMyCustomTopics
    //                         query where('groupId','==',null))
    //   - groupId != null  -> 'group'   (matches old getGroupCustomTopics
    //                         query where('groupId','==',X))
    // Without this mapping, legacy group-shared topics would silently
    // lose read-access for group-members the moment this rule deploys
    // (the old rule `allow read,list: if isAuth()` was wide-open). New
    // topics from the Phase-3a builder always set `visibility` explicitly
    // so the legacy branch is never hit for them.
    function customTopicReadOk() {
      return (
        // Owner always reads.
        request.auth.uid == resource.data.get('ownerUid', null)
        // Public — every authed user reads.
        || resource.data.get('visibility', 'private') == 'public'
        // Group — caller must have topic.groupId in their groupIds.
        // Includes the legacy-compat mapping: a doc with no `visibility`
        // field but a non-null `groupId` is treated as 'group'-shared.
        // We collapse the legacy-vs-new check into one expression by
        // using `resource.data.get('visibility', 'group')` ONLY when
        // groupId is non-null — that way the default for "groupId set,
        // no visibility" is 'group', and for "groupId null, no visibility"
        // is moot (the AND guard fails on groupId==null anyway).
        // The per-rule `get(/users/{uid})` is the same pattern the
        // friendRequests cross-check uses (line 406-413) so we know
        // it works in production. One server-side doc read per evaluation.
        || (
             resource.data.get('groupId', null) != null
             && resource.data.get('visibility', 'group') == 'group'
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             && resource.data.groupId in get(/databases/$(database)/documents/users/$(request.auth.uid))
                            .data.get('groupIds', [])
           )
        // Admin-role reads everything.
        || isAdmin()
      );
    }
    // The set of `visibility` values a non-admin client may write. Worker-
    // only states ('pending-approval', 'public') are intentionally absent
    // — those transitions come from submitTopicForApproval and
    // approveTopicForPublic respectively.
    function clientWritableVisibility(v) {
      return v == 'private' || v == 'group';
    }
    match /customTopics/{topicId} {
      allow get:    if isAuth() && customTopicReadOk();
      // V-PHASE-E-09 (Ramsey Cycle-E, P2 documented for Mission-13,
      // 2026-05-08): `list: isAuth()` lets every authed user enumerate
      // metadata of EVERY customTopic doc in the collection — including
      // private/pending-approval ones (which fail get-rule but show up
      // in list-snapshots until the per-doc filter runs). Mitigation
      // here is a no-op (Mission-13 fix: dedicated Worker endpoint
      // `getCustomTopicsForUser(scope)` returns scope-filtered results
      // via service-account; client list-query then deleted entirely).
      // Marker comment + TODO so the audit-trail is visible.
      // TODO(Mission-13): tighten customTopics.list to scope-filtered
      //                   Worker endpoint; remove this rule case.
      allow list:   if isAuth();
      allow create: if isAuth()
                     && request.resource.data.ownerUid == request.auth.uid
                     && (
                          !('visibility' in request.resource.data)
                          || clientWritableVisibility(request.resource.data.visibility)
                        );
      // V-PHASE-E-02 / V-PHASE-E-03 / V-PHASE-E-06 (Ramsey Cycle-E, P1,
      // 2026-05-08, Marcus):
      //
      //  V-02 — Post-approval content swap (rugpull XSS): without a freeze
      //  on public-state edits, an owner could approve a topic, then
      //  `set({content, questions:[<malicious>]}, {merge:true})` and the
      //  Public-Library would silently serve the poisoned content (rules
      //  can't enforce per-character sanitisation; the only meaningful
      //  bound is "don't let content drift after approval"). Fix:
      //  whenever resource.data.visibility == 'public', the owner can ONLY
      //  perform a self-unpublish — i.e. visibility-only diff, new value
      //  in ('private'|'group'). Any other edit on a public topic is
      //  denied; owner has to unpublish, edit, re-submit, re-approve.
      //
      //  V-03 — rejectionNote bypass: the queue audit-trail fields
      //  (rejectionNote, rejectedAt, approvedAt, approvedBy,
      //  pendingApprovalId) and the queue-submission fields (submittedAt)
      //  are Worker-only. Without this block an owner could
      //  `set({rejectionNote: null}, {merge:true})` directly and erase
      //  the rejection audit-trail — UI would render "no rejection" again
      //  and the next submitTopicForApproval would have no history.
      //  All five flow exclusively through approveTopicForPublic /
      //  submitTopicForApproval (service-account writes that bypass
      //  these rules).
      //
      //  V-06 — submittedMessage size cap: defense-in-depth bound on the
      //  size of submittedMessage. The Worker already caps at 1000 chars,
      //  this is the matching rule-level guard for any bypass we missed.
      //  We allow up to 1500 here so a future Worker bump to a higher
      //  cap doesn't immediately collide.
      allow update: if isAuth() && (
                       isAdmin()
                       || isAdminEmail()
                       || (
                            resource.data.ownerUid == request.auth.uid
                            // V-03: Worker-only fields are off-limits to
                            // the owner. submittedAt is added too because
                            // the queue-status timestamp is part of the
                            // audit-trail (faking it back-dates queue
                            // priority). submittedMessage stays owner-
                            // writable because (a) the legitimate path
                            // is Worker-set on submit, (b) V-06 caps it,
                            // and (c) future re-submit flows might reuse
                            // it for an "edit-and-resubmit" UX.
                            && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                                 'rejectionNote', 'rejectedAt',
                                 'approvedAt', 'approvedBy',
                                 'pendingApprovalId', 'submittedAt'
                               ])
                            // V-02: post-approval freeze. If the existing
                            // doc is 'public', the only legal owner-write
                            // is a self-unpublish (visibility-only diff
                            // moving to 'private' or 'group'). Any other
                            // diff on a public doc is denied — public
                            // content is immutable until the owner cycles
                            // back through unpublish + re-submit + admin.
                            && (
                                 resource.data.get('visibility', 'private') != 'public'
                                 || (
                                      onlyChanged(['visibility'])
                                      && clientWritableVisibility(request.resource.data.visibility)
                                    )
                               )
                            // Visibility writes from non-public state stay
                            // in the client-writable set (no skip-the-queue
                            // by self-promoting to 'public' or 'pending-
                            // approval'). Worker writes via service-account.
                            && (
                                 !('visibility' in request.resource.data.diff(resource.data).affectedKeys())
                                 || clientWritableVisibility(request.resource.data.visibility)
                               )
                            // V-06: defense-in-depth size cap on
                            // submittedMessage. Worker cap is 1000; we
                            // allow some headroom (1500) so a Worker
                            // bump doesn't immediately bite this rule.
                            && (
                                 !('submittedMessage' in request.resource.data.diff(resource.data).affectedKeys())
                                 || request.resource.data.get('submittedMessage', '').size() <= 1500
                               )
                          )
                     );
      allow delete: if isAuth() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── pendingApprovals ──────────────────────────────────────────────────
    // Phase 3c (Marcus, 2026-05-08): admin-only queue collection. Rows
    // are created by the submitTopicForApproval Worker (service-account,
    // bypasses these rules) and resolved by the approveTopicForPublic
    // Worker. NO client write surface — every state transition flows
    // through a Worker so we keep server-side validation centralised.
    //
    // Read access: admin-email whitelist OR users with role:'admin' on
    // their user-doc. The Admin-UI in app.js polls this collection
    // every N seconds; the auth-email check via the verified ID-token
    // is enough — leaked tester credentials cannot promote to admin
    // (V-03 split, see adminEmails() / testerEmails() above).
    //
    // Owner-of-topic does NOT need read access here: the topic itself
    // carries `submittedAt`/`pendingApprovalId`/`rejectionNote` so the
    // builder UI shows the queue-status without touching this collection.
    match /pendingApprovals/{queueId} {
      // V-PHASE-E-05 (2026-05-08): isAdminEmail() now requires
      // email_verified=true (defense-in-depth against unverified-email
      // impersonation, matches the Worker's check in approveTopicForPublic).
      allow read, list: if isAuth() && (isAdminEmail() || isAdmin());
      // No client writes. Worker has service-account credentials and
      // bypasses these rules.
    }

    // ── pendingTopics ─────────────────────────────────────────────────────
    // REMOVED (Mission 2 / Cheat #12 + Ghost-Code finding). The collection
    // is dead — submitTopicForReview / voteCustomTopic / getPendingTopics
    // were imported but never called. Wrapper functions deleted from
    // auth.js in the same commit.

    // ── dailyScores ───────────────────────────────────────────────────────
    // Cheat #4 FULLY closed (Mission 2 Phase 3, Marcus, 2026-05-07):
    // Client-side writes are now blocked entirely. The submitDailyChallenge
    // Cloud Worker writes via Service-Account and bypasses these rules, so
    // legitimate score submissions still work. Admin write stays open for
    // manual anomaly correction via admin tooling. Reads remain auth-only
    // so the leaderboard / daily-Rangleichne UI keeps working.
    match /dailyScores/{date} {
      allow read, list: if isAuth();
    }
    match /dailyScores/{date}/users/{uid} {
      allow read, list: if isAuth();
      allow write:      if isAdmin();
    }

    // ── feed ──────────────────────────────────────────────────────────────
    // Cheat #13: only the original author may update/delete their feed entry.
    match /feed/{entryId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── comments ──────────────────────────────────────────────────────────
    // Topic-Doc selbst (kann auch leer sein, dient nur als Container fuer die Subcollection)
    match /comments/{topicKey} {
      allow read, list: if isAuth();
      // Auto-create implizit erlaubt (fuer Kommentar-Subcollection-Anlage)
      allow create:     if isAuth();
    }
    // Kommentar-Eintraege — DAS ist die richtige Stelle (Subcollection!)
    // Cheat #11: likes-only branch tightened. A user may only flip THEIR
    // OWN key in the likes map, not the entire map.
    //
    // Wave-1 hardening 2026-05-08 (Marcus, CHEAT-30/33):
    //   - On create, the comment author's `name`/`photo`/`role` MUST mirror
    //     their users/{uid} doc (no admin-impersonation in the comment
    //     bubble UI).
    //   - `text` capped at 2000 chars — prevents user-doc-bloat / 1MB-DoS
    //     via giant-comment spam.
    //   - `createdAt` MUST equal request.time (no future-dated or
    //     backdated comments to game ordering).
    match /comments/{topicKey}/entries/{commentId} {
      allow read, list: if isAuth();
      allow create:     if isAuth()
                         && request.resource.data.uid == request.auth.uid
                         && request.resource.data.text is string
                         && request.resource.data.text.size() <= 2000
                         && request.resource.data.createdAt == request.time
                         && request.resource.data.name
                              == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('name', null)
                         && (
                              request.resource.data.photo == null
                              || request.resource.data.photo
                                   == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('photoURL', null)
                            )
                         && request.resource.data.get('role', null)
                              == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null);
      allow update:     if isAuth() && (
                            resource.data.uid == request.auth.uid
                            || isAdmin()
                            || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
                                && request.resource.data.likes.diff(resource.data.likes)
                                      .affectedKeys().hasOnly([request.auth.uid]))
                          );
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── shareLinks ────────────────────────────────────────────────────────
    // Cheat #17 (partial): tightened to owner-only read on the token doc.
    // The frontend share-bericht route still reads the linked users/{uid}
    // doc directly — Ethan owns the deeper fix (curated payload via a
    // future shareData Cloud Function in Mission 3). For now: lock down
    // the shareLinks doc itself so it cannot be enumerated.
    //
    // Wave-1 hardening 2026-05-08 (Marcus, CHEAT-38): expiry-stamp now
    // required at create-time. The worker `getParentShareReport` checks
    // `expiresAt > now` and rejects expired links. The rule does not
    // enforce a max-TTL on create (the client picks the value), but it
    // requires the field to be present so leaked old tokens cannot be
    // re-purposed indefinitely.
    match /shareLinks/{tokenId} {
      allow get, list:  if isAuth() && resource.data.uid == request.auth.uid;
      allow create:     if isAuth()
                         && request.resource.data.uid == request.auth.uid
                         && request.resource.data.expiresAt is number;
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── appConfig ─────────────────────────────────────────────────────────
    // B-M01 (Wave-1, Marcus, 2026-05-08): admin-only writes for app-wide
    // configuration. The Admin-Tab's "Hilfsmittel speichern" button
    // (app.js:6741) writes appConfig/subjectTools to override per-subject
    // calculator/tafelwerk visibility. Without this rule the write was
    // permission-denied, the toast was an error, and any saved override
    // never persisted. Read is open to all authed users so the loadpath
    // (app.js:8767) can apply the override to render-time tool gating.
    match /appConfig/{docId} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── bugReports ────────────────────────────────────────────────────────
    // Cheat #16: bind report.uid to request.auth.uid on create (already
    // done — restated explicitly here for clarity).
    //
    // Wave-1 hardening 2026-05-08 (Marcus, CHEAT-29): name + photoURL on
    // the bug-report MUST mirror the reporter's users/{uid} doc — without
    // this an attacker could file a "bug" as "Simon (admin)" and bait the
    // real admin into clicking a phishing link from the bug-resolve UI.
    // The auth-pair binding is on uid (already enforced), the display
    // fields are now also pinned.
    match /bugReports/{reportId} {
      allow read, list: if isAuth();
      allow create:     if isAuth()
                         && request.resource.data.uid == request.auth.uid
                         && request.resource.data.name
                              == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('name', null)
                         && (
                              request.resource.data.photoURL == null
                              || request.resource.data.photoURL
                                   == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('photoURL', null)
                            );
      allow update:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
