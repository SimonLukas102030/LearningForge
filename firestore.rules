rules_version = '2';

// ════════════════════════════════════════════════════════════════════════════
//  LearningForge — Firestore Security Rules
//
//  Deploy: firebase deploy --only firestore:rules
// ════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── helper functions ──────────────────────────────────────────────────
    function isAuth()        { return request.auth != null; }
    function isOwner(uid)    { return isAuth() && request.auth.uid == uid; }
    function isAdmin()       { return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
                                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function onlyChanged(fs) { return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fs); }

    // ── users ─────────────────────────────────────────────────────────────
    // Read/List: jeder authentifizierte User darf User-Profile lesen.
    // Create:    nur eigenes Doc.
    // Update:
    //   - eigenes Doc: alles erlaubt
    //   - Admin: alles erlaubt (für Role-Management)
    //   - fremdes Doc: nur friendRequests + friendIds darf modifiziert werden
    //                  (für Friend-Request senden bzw. accept)
    // Delete:    nur eigenes Doc oder Admin.
    match /users/{uid} {
      allow read, list: if isAuth();
      allow create:     if isOwner(uid);
      allow update:     if isOwner(uid)
                         || isAdmin()
                         || (isAuth() && onlyChanged(['friendRequests', 'friendIds']));
      allow delete:     if isOwner(uid) || isAdmin();
    }

    // ── groups ────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.creatorUid == request.auth.uid;
      allow update:     if isAuth()
                         && (resource.data.creatorUid == request.auth.uid
                             || isAdmin()
                             || onlyChanged(['members']));
      allow delete:     if isAuth() && (resource.data.creatorUid == request.auth.uid || isAdmin());
    }

    // ── leaderboard ───────────────────────────────────────────────────────
    match /leaderboard/{uid} {
      allow read, list: if isAuth();
      allow write:      if isOwner(uid) || isAdmin();
    }

    // ── customTopics ──────────────────────────────────────────────────────
    match /customTopics/{topicId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update:     if isAuth() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow delete:     if isAuth() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── pendingTopics ─────────────────────────────────────────────────────
    match /pendingTopics/{topicId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.submittedBy == request.auth.uid;
      allow update:     if isAuth();
      allow delete:     if isAuth();
    }

    // ── dailyScores ───────────────────────────────────────────────────────
    match /dailyScores/{date} {
      allow read, list: if isAuth();
    }
    match /dailyScores/{date}/users/{uid} {
      allow read, list: if isAuth();
      allow write:      if isOwner(uid) || isAdmin();
    }

    // ── feed ──────────────────────────────────────────────────────────────
    match /feed/{entryId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update:     if isAuth();
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── comments ──────────────────────────────────────────────────────────
    // Topic-Doc selbst (kann auch leer sein, dient nur als Container für die Subcollection)
    match /comments/{topicKey} {
      allow read, list: if isAuth();
      // Auto-create implizit erlaubt (für Kommentar-Subcollection-Anlage)
      allow create:     if isAuth();
    }
    // Kommentar-Einträge — DAS ist die richtige Stelle (Subcollection!)
    match /comments/{topicKey}/entries/{commentId} {
      allow read, list: if isAuth();
      allow create:     if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update:     if isAuth() && (resource.data.uid == request.auth.uid
                                         || isAdmin()
                                         || onlyChanged(['likes']));
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ── shareTokens ───────────────────────────────────────────────────────
    match /shareTokens/{tokenId} {
      allow read, list: if true;
      allow create:     if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete:     if isAuth() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
